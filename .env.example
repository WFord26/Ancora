# Database (Docker)
# For Docker Compose, use these settings:
DATABASE_URL="postgresql://ancora:ancora_dev_password@localhost:5432/ancora?schema=public"

# Database Configuration (used by docker-compose.yml)
POSTGRES_USER=ancora
POSTGRES_PASSWORD=ancora_dev_password
POSTGRES_DB=ancora
POSTGRES_PORT=5432

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Redis (Docker)
REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# pgAdmin (optional, use with: docker compose --profile tools up)
PGADMIN_EMAIL=admin@ancora.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Azure Blob Storage (optional in dev)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_NAME=""

# Email
EMAIL_FROM="noreply@example.com"
RESEND_API_KEY=""
